generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Review {
  id          String   @id @default(cuid())
  productSlug String
  authorName  String
  rating      Int
  comment     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productSlug, createdAt(sort: Desc)])
}
